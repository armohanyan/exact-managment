{
  "baseName": "Exact Management",
  "tables": [
    {
      "name": "Courses",
      "description": "Training courses shown on /training and /training/[slug]",
      "fields": [
        { "name": "Slug", "type": "singleLineText", "required": true },
        { "name": "Title (EN)", "type": "singleLineText" },
        { "name": "Title (AM)", "type": "singleLineText" },
        { "name": "Title (RU)", "type": "singleLineText" },
        { "name": "Overview (EN)", "type": "multilineText" },
        { "name": "Overview (AM)", "type": "multilineText" },
        { "name": "Overview (RU)", "type": "multilineText" },
        { "name": "Topics", "type": "multilineText", "hint": "One topic per line (fallback if lang-specific empty)" },
        { "name": "Topics (EN)", "type": "multilineText", "hint": "One topic per line" },
        { "name": "Topics (AM)", "type": "multilineText", "hint": "One topic per line" },
        { "name": "Topics (RU)", "type": "multilineText", "hint": "One topic per line" },
        { "name": "Outcomes", "type": "multilineText", "hint": "One per line (fallback)" },
        { "name": "Outcomes (EN)", "type": "multilineText", "hint": "One per line" },
        { "name": "Outcomes (AM)", "type": "multilineText", "hint": "One per line" },
        { "name": "Outcomes (RU)", "type": "multilineText", "hint": "One per line" },
        { "name": "Audience", "type": "multilineText", "hint": "One per line (fallback)" },
        { "name": "Audience (EN)", "type": "multilineText", "hint": "One per line" },
        { "name": "Audience (AM)", "type": "multilineText", "hint": "One per line" },
        { "name": "Audience (RU)", "type": "multilineText", "hint": "One per line" },
        { "name": "Register URL", "type": "url" },
        { "name": "Location", "type": "singleLineText", "hint": "Fallback if lang-specific empty" },
        { "name": "Location (EN)", "type": "singleLineText" },
        { "name": "Location (AM)", "type": "singleLineText" },
        { "name": "Location (RU)", "type": "singleLineText" },
        { "name": "Instructor", "type": "singleLineText", "hint": "Fallback if lang-specific empty" },
        { "name": "Instructor (EN)", "type": "singleLineText" },
        { "name": "Instructor (AM)", "type": "singleLineText" },
        { "name": "Instructor (RU)", "type": "singleLineText" },
        { "name": "Format", "type": "singleLineText", "hint": "Fallback if lang-specific empty" },
        { "name": "Format (EN)", "type": "singleLineText" },
        { "name": "Format (AM)", "type": "singleLineText" },
        { "name": "Format (RU)", "type": "singleLineText" },
        { "name": "Duration", "type": "singleLineText", "hint": "Fallback if lang-specific empty" },
        { "name": "Duration (EN)", "type": "singleLineText" },
        { "name": "Duration (AM)", "type": "singleLineText" },
        { "name": "Duration (RU)", "type": "singleLineText" },
        { "name": "Schedule", "type": "singleLineText", "hint": "Fallback if lang-specific empty" },
        { "name": "Schedule (EN)", "type": "singleLineText" },
        { "name": "Schedule (AM)", "type": "singleLineText" },
        { "name": "Schedule (RU)", "type": "singleLineText" },
        { "name": "Image URL", "type": "url" },
        { "name": "Sort", "type": "number" }
      ]
    },
    {
      "name": "Projects",
      "description": "Done and ongoing projects on /projects",
      "fields": [
        { "name": "Name (EN)", "type": "singleLineText" },
        { "name": "Name (AM)", "type": "singleLineText" },
        { "name": "Name (RU)", "type": "singleLineText" },
        { "name": "Description (EN)", "type": "multilineText" },
        { "name": "Description (AM)", "type": "multilineText" },
        { "name": "Description (RU)", "type": "multilineText" },
        { "name": "Status", "type": "singleSelect", "options": ["Ongoing", "Completed"] },
        { "name": "Image URL", "type": "url" },
        { "name": "Sort", "type": "number" }
      ]
    },
    {
      "name": "Team",
      "description": "Team members on /about",
      "fields": [
        { "name": "Name", "type": "singleLineText", "hint": "Fallback if lang-specific empty" },
        { "name": "Name (EN)", "type": "singleLineText" },
        { "name": "Name (AM)", "type": "singleLineText" },
        { "name": "Name (RU)", "type": "singleLineText" },
        { "name": "Role (EN)", "type": "singleLineText" },
        { "name": "Role (AM)", "type": "singleLineText" },
        { "name": "Role (RU)", "type": "singleLineText" },
        { "name": "Image URL", "type": "url" },
        { "name": "Sort", "type": "number" }
      ]
    },
    {
      "name": "Contacts",
      "description": "Contact form submissions; use Airtable Automation to send email on new record",
      "fields": [
        { "name": "Name", "type": "singleLineText" },
        { "name": "Email", "type": "email" },
        { "name": "Message", "type": "multilineText" },
        { "name": "Created", "type": "createdTime" }
      ]
    },
    {
      "name": "Hero",
      "description": "Home hero block: title, subtitle, lead (one record used). Optional; app falls back to translations if empty.",
      "fields": [
        { "name": "Title (EN)", "type": "singleLineText" },
        { "name": "Title (AM)", "type": "singleLineText" },
        { "name": "Title (RU)", "type": "singleLineText" },
        { "name": "Subtitle (EN)", "type": "singleLineText" },
        { "name": "Subtitle (AM)", "type": "singleLineText" },
        { "name": "Subtitle (RU)", "type": "singleLineText" },
        { "name": "Lead (EN)", "type": "multilineText" },
        { "name": "Lead (AM)", "type": "multilineText" },
        { "name": "Lead (RU)", "type": "multilineText" },
        { "name": "Sort", "type": "number" }
      ]
    },
    {
      "name": "HeroSlides",
      "description": "Home hero carousel slides: image and alt text per language. Optional; app falls back to default images/translations if empty.",
      "fields": [
        { "name": "Image URL", "type": "url" },
        { "name": "Alt (EN)", "type": "singleLineText" },
        { "name": "Alt (AM)", "type": "singleLineText" },
        { "name": "Alt (RU)", "type": "singleLineText" },
        { "name": "Sort", "type": "number" }
      ]
    }
  ]
}
